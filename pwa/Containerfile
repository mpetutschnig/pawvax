# Build stage
FROM docker.io/node:22-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci
COPY . .
# Sentry/GlitchTip — baked at build time (frontend DSN is public by design)
ARG VITE_SENTRY_DSN=""
ARG VITE_SENTRY_RELEASE=""
ARG VITE_SENTRY_TRACES_SAMPLE_RATE=""
ENV VITE_SENTRY_DSN=$VITE_SENTRY_DSN
ENV VITE_SENTRY_RELEASE=$VITE_SENTRY_RELEASE
ENV VITE_SENTRY_TRACES_SAMPLE_RATE=$VITE_SENTRY_TRACES_SAMPLE_RATE
RUN npm run build
RUN node -e "process.stdout.write(require('./package.json').version)" > /version.txt

FROM docker.io/nginx:alpine

RUN rm /etc/nginx/conf.d/default.conf

COPY nginx-prod.conf /etc/nginx/conf.d/default.conf.tpl
COPY --from=builder /app/dist /usr/share/nginx/html
COPY --from=builder /version.txt /version.txt

EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=5s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost:8080/ || exit 1

CMD sh -c "export APP_VERSION=\$(cat /version.txt) && envsubst '\${APP_VERSION}' < /etc/nginx/conf.d/default.conf.tpl > /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"
