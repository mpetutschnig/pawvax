    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.1.0",
    "@fastify/websocket": "^10.0.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.6.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
